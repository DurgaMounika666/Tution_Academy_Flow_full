# ============================================
# Academy Flow — Frontend Environment Variables Example
# ============================================
# Copy this file to .env and fill in your values.

# GEMINI_API_KEY: Required for Gemini AI API calls if done client-side
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted
APP_URL="MY_APP_URL"

# VITE_API_URL: The URL of the backend API
# Vite requires variables to start with VITE_ to be exposed to your React code
VITE_API_URL="http://localhost:5000/api"
